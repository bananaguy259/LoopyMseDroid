<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.LoopyMseDroid" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorSurfaceVariant">@color/bg_elevated</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorPrimary">@color/text_primary</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorPrimaryContainer">@color/bg_elevated</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/text_secondary</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="colorOutline">@color/border</item>
        <item name="colorOutlineVariant">@color/border</item>
        <item name="android:statusBarColor">@color/statusbar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:colorControlHighlight">@color/ripple</item>
        <item name="rippleColor">@color/ripple</item>
    </style>

    <style name="Theme.LoopyMseDroid.Emulator" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
    </style>

    <!-- Toolbar widget style -->
    <style name="LoopyToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/bg_primary</item>
        <item name="android:elevation">0dp</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <!-- ROM list item style — explicit parent avoids implicit dot-hierarchy lookup -->
    <style name="LoopyRomItem" parent="">
        <item name="android:background">@drawable/bg_rom_item</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>

</resources>
