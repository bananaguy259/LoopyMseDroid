<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_primary">

    <!-- Left panel: explanation text -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="48dp"
        android:paddingEnd="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bios_setup_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bios_setup_body"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.5" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/bios_optional_note"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

    <!-- Right panel: file pickers + continue button -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="32dp"
        android:paddingEnd="48dp">

        <!-- Main BIOS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Main BIOS"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_file_picker"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_bios_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/bios_not_selected"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_bios"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/select_main_bios"
                android:textSize="12sp"
                app:backgroundTint="@color/bg_surface"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Sound BIOS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sound BIOS"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_file_picker"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_sound_bios_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/bios_not_selected"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_sound_bios"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/select_sound_bios"
                android:textSize="12sp"
                app:backgroundTint="@color/bg_surface"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Error text (shows if try to continue without required BIOS) -->
        <TextView
            android:id="@+id/tv_bios_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/bios_missing_warning"
            android:textSize="12sp"
            android:textColor="#CC4444"
            android:visibility="gone" />

        <!-- Continue button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="32dp"
            android:text="@string/bios_continue"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/text_primary"
            android:textColor="@color/bg_primary"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

</LinearLayout>
