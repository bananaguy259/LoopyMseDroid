<?xml version="1.0" encoding="utf-8"?>
<!--
    Main ROM library screen.
    Layout: Eden-inspired dark UI with a list (not grid) of ROMs.
    Top bar: app title (left) + search bar (center) + icons (right)
    Body: RecyclerView list with clean row items
    FAB: + button to add a ROM
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".ui.MainActivity">

    <!-- Top bar: fixed, not scrolling -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_primary"
        app:layout_constraintTop_toTopOf="parent">

        <!-- App title: bold, white, left-aligned — mirrors Eden's bold branding -->
        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:letterSpacing="-0.02"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="20dp" />

        <!-- Search bar: pill-shaped, centered, takes available width -->
        <com.google.android.material.search.SearchBar
            android:id="@+id/search_bar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/search_hint"
            android:textColorHint="@color/text_hint"
            app:navigationIcon="@drawable/ic_search"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:surfaceColor="@color/bg_input"
            app:hintTextColor="@color/text_hint"
            app:defaultModeTextColor="@color/text_primary" />

        <!-- Right-side icon buttons: mirror Eden's eye / filter / settings icons -->
        <ImageButton
            android:id="@+id/btn_sort"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_sort"
            android:tint="@color/icon_primary"
            android:contentDescription="Sort"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_settings"
            android:tint="@color/icon_primary"
            android:contentDescription="Settings"
            android:padding="10dp" />

    </LinearLayout>

    <!-- Divider under top bar -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="72dp"
        android:background="@color/border" />

    <!-- ROM list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_roms"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="73dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbars="none"
        tools:listitem="@layout/item_rom" />

    <!-- Empty state: shown when no ROMs are loaded -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="73dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Simple chip/cartridge icon placeholder -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_cartridge"
            android:tint="@color/text_tertiary"
            android:contentDescription="" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/no_roms_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/no_roms_body"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

    <!-- FAB: Add ROM button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_rom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add"
        android:contentDescription="@string/add_rom"
        app:backgroundTint="@color/bg_elevated"
        app:tint="@color/text_primary"
        app:elevation="4dp"
        app:borderWidth="1dp" />

    <!-- BIOS warning banner: shown at bottom when BIOS is missing -->
    <LinearLayout
        android:id="@+id/bios_warning_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="80dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_warning_banner"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BIOS files not configured. Tap to set up."
            android:textSize="13sp"
            android:textColor="@color/warning_text" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_right"
            android:tint="@color/warning_text"
            android:contentDescription="" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
