<?xml version="1.0" encoding="utf-8"?>
<!--
    Pause menu overlay.
    Semi-transparent dark background + vertical button list.
    Triggered by back button or swipe-down during gameplay.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <!-- Centered card containing menu items -->
    <androidx.cardview.widget.CardView
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardBackgroundColor="@color/bg_elevated"
        app:cardCornerRadius="16dp"
        app:cardElevation="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- PAUSED header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/paused"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:gravity="center"
                android:textAllCaps="true" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border" />

            <!-- Resume -->
            <TextView
                android:id="@+id/menu_resume"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/resume"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:fontFamily="sans-serif-medium" />

            <!-- Reset -->
            <TextView
                android:id="@+id/menu_reset"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/reset_console"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- Screenshot -->
            <TextView
                android:id="@+id/menu_screenshot"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/take_screenshot"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- Load ROM -->
            <TextView
                android:id="@+id/menu_load_rom"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/load_rom"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- Settings -->
            <TextView
                android:id="@+id/menu_settings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/settings"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border" />

            <!-- Quit -->
            <TextView
                android:id="@+id/menu_quit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/quit_game"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackground" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
